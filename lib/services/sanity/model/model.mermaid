 
 classDiagram
     direction TB
 
     class mal["mal · Hovedmal"] {
         <<document>>
         +string beskrivelse
         +i18n overskrift
         +string journalposttittel
         +boolean kanSendesAutomatisk
     }
 
     class delmalRef["delmalRef"] {
         <<object>>
         +ref delmal
         +boolean obligatorisk
     }
 
     class delmal["delmal · Delmal"] {
         <<document>>
         +string beskrivelse
         +i18n overskrift
         +string paragraf
     }
 
     class teksteditor["teksteditor"] {
         <<i18n array field>>
         valgRef
         betingetTekstRef
         fritekst
         block~faktagrunnlag~
     }
 
     class valgRef["valgRef"] {
         <<object>>
         +ref valg
         +boolean obligatorisk
     }
 
     class valg["valg · Valg"] {
         <<document>>
         +string beskrivelse
         +string language
     }
 
     class kategorisertTekstRef["kategorisertTekstRef"] {
         <<object>>
         +ref tekst
         +ref kategori
     }
 
     class betingetTekstRef["betingetTekstRef"] {
         <<object>>
         +ref tekst
         +kategori[] kategorier
     }
 
     class fritekst["fritekst"] {
         <<object>>
         +string fritekst
     }
 
     class tekst["tekst · Tekst"] {
         <<document>>
         +string beskrivelse
         +blockEditor teksteditor
     }
 
     class kategori["kategori · Kategori"] {
         <<document>>
         +string visningsnavn
         +string tekniskNavn
     }
 
     class faktagrunnlag["faktagrunnlag · Faktagrunnlag"] {
         <<document>>
         +string visningsnavn
         +string datatype
         +string tekniskNavn
     }
 
     mal "1" *-- "*" delmalRef : delmaler
     delmalRef --> "1" delmal
     delmal *-- "1" teksteditor
     teksteditor *-- "*" valgRef
     teksteditor *-- "*" betingetTekstRef
     teksteditor *-- "*" fritekst
     teksteditor ..> faktagrunnlag : inline block ref
     valgRef --> "1" valg
     valg *-- "*" kategorisertTekstRef : alternativer
     valg *-- "*" fritekst : alternativer
     kategorisertTekstRef --> "1" tekst
     kategorisertTekstRef --> "1" kategori
     betingetTekstRef --> "1" tekst
     betingetTekstRef --> "*" kategori : kategorier
     tekst ..> faktagrunnlag : inline block ref
